{
    "name": "mele-vite-react-typescript-template",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "check": "pnpm format:check && pnpm lint:js:check && pnpm test:coverage",
        "format:check": "prettier --config .prettierrc --check .",
        "format:fix": "prettier --config .prettierrc --write .",
        "lint:js:check": "eslint .",
        "lint:js:fix": "eslint . --fix",
        "test": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui"
    },
    "dependencies": {
        "react": "^19.2.5",
        "react-dom": "^19.2.5"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/jsdom": "^28.0.1",
        "@types/node": "^24.12.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/coverage-v8": "4.1.4",
        "@vitest/ui": "4.1.4",
        "eslint": "^9.39.4",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.5.0",
        "jsdom": "^29.1.1",
        "prettier": "3.8.3",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.58.2",
        "vite": "^8.0.9",
        "vitest": "^4.1.4"
    },
    "packageManager": "pnpm@10.33.0"
}
